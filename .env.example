# Puerto donde corre el servidor backend
PORT=3001

# URL completa de la base de datos MySQL
DATABASE_URL=mysql://root:@localhost:3306/recetario

# Secreto para firmar tokens JWT (cambiar en producción)
JWT_SECRET=recetario_cambiable

# Entorno: development (local) o production (producción)
NODE_ENV=development

# Origen permitido para CORS (frontend que consume la API)
CORS_ORIGIN=http://localhost:3000

# URL de la API para el frontend (Vite/Nuxt)
VITE_API_URL=http://localhost:3000